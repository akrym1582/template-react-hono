# Azure Entra ID (formerly Azure AD)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_AZURE_CLIENT_ID=your-client-id

# App auth session
AUTH_JWT_SECRET=replace-with-a-long-random-string
AUTH_JWT_ISSUER=template-react-hono
AUTH_JWT_AUDIENCE=template-react-hono
AUTH_COOKIE_NAME=app_session
AUTH_COOKIE_MAX_AGE=28800

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=your-database
COSMOS_CONTAINER=SampleItems

# Azure Storage (Blob / Table / Queue)
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
USER_TABLE_NAME=Users

# App
PORT=3000
NODE_ENV=development
