{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@client/*": ["./client/*"],
      "@server/*": ["./server/*"]
    }
  },
  "include": ["server", "client", "shared"],
  "exclude": ["node_modules", "public", "dist"]
}
