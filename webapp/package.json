{
  "name": "template-react-hono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/dev.ts",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run --config ../tests/vitest.config.ts"
  },
  "dependencies": {
    "@azure/cosmos": "^4.1.1",
    "@azure/data-tables": "^13.3.2",
    "@azure/msal-browser": "^4.30.0",
    "@azure/msal-react": "^3.0.29",
    "@azure/storage-blob": "^12.26.0",
    "@azure/storage-queue": "^12.29.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@testing-library/dom": "^10.4.1",
    "argon2": "^0.44.0",
    "clsx": "^2.1.1",
    "hono": "^4.7.4",
    "inversify": "^7.10.3",
    "jose": "^5.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "reflect-metadata": "^0.2.2",
    "sweetalert2": "^11.26.24",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.12",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^8.0.3",
    "vitest": "^3.0.8"
